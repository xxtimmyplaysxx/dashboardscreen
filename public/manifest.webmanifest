{
  "name": "Bildschirmdashboard",
  "short_name": "Dashboard",
  "description": "Ein ruhiges, persönliches Tablet-Dashboard für Arbeitsplatz-Displays.",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#f5f5f7",
